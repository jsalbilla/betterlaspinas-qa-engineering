{
  "name": "betterlaspinas-qa-engineering",
  "version": "1.0.0",
  "description": "QA Strategy, Manual Test Suites, and Automation Scripts for the Better Las Piñas project.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test:e2e": "npx playwright test && npx playwright show-report",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:chromium": "npx playwright test --project chromium",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:codegen": "npx playwright codegen",
    "test:e2e:local": "BASE_URL=http://localhost:4200 npx playwright test",
    "test:e2e:file": "npx playwright test tests/api.spec.ts",
    "test:e2e:line": "npx playright test tests/api.spec.ts:10:", 
    "test:e2e:sanity": "npx playwright test --grep @firsts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsalbilla/betterlaspinas-qa-engineering.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jsalbilla/betterlaspinas-qa-engineering/issues"
  },
  "homepage": "https://github.com/jsalbilla/betterlaspinas-qa-engineering#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  }
}
